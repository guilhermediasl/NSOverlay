{
    "nightscout_url": "https://your-site.fly.dev",
    "api_secret": "your_api_secret_here",
    "refresh_interval_ms": 60000,
    "timezone_offset_hours": 0,
    "time_window_hours": 3,
    "entries_to_fetch": 90,
    "target_low": 70,
    "target_high": 180,
    "widget_width": 400,
    "widget_height": 280,
    "glucose_font_size": 18,
    "time_font_size": 12,
    "age_font_size": 10,
    "show_delta": true,
    "show_float_glucose": true,
    "adaptive_dot_size": false,
    "data_point_size": 6,
    "show_treatments": true,
    "treatments_to_fetch": 50,
    "default_insulin_type": "Humalog Lispro",
    "iob_dia_hours": 5.0,
    "iob_peak_minutes": 75,
    "iob_onset_minutes": 15,
    "gradient_interpolation": false,
    "header_pills": [
        {
            "event_types": [
                "Bolus",
                "Meal Bolus",
                "Correction Bolus"
            ],
            "label": "Bolus Today",
            "show_fields": ["insulin", "carbs"],
            "suffix_map": {"insulin": "U", "carbs": "g"},
            "enabled": true,
            "sum_daily": true
        }
    ],
    "appearance": {
        "graph_background_opacity": 100,
        "transparency_enabled": true,
        "label_pill_opacity": 40,
        "marker_outline_width": 1.5,
        "marker_outline_color": "#000000",
        "graph_line_width": 2,
        "graph_line_style": "solid",
        "graph_line_smooth": true,
        "show_y_label": true,
        "target_zone_opacity": 20,
        "grid_opacity": 0.3,
        "background_color": "#1a1a1a"
    }
}